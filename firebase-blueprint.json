{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A luxury item sold in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "discountPrice": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" },
        "isFeatured": { "type": "boolean" },
        "isNewArrival": { "type": "boolean" },
        "isBestSeller": { "type": "boolean" },
        "ratings": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "specs": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "images"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "paymentMethod": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "contactInfo": { "type": "object" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "total", "status", "paymentMethod"]
    },
    "Review": {
      "title": "Review",
      "description": "Customer review for a product",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "rating", "comment"]
    },
    "Brand": {
      "title": "Brand",
      "description": "Watch brand",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "slug": { "type": "string" }
      },
      "required": ["name", "slug"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "categories": {
      "schema": "Category",
      "description": "Collection of categories"
    },
    "brands": {
      "schema": "Brand",
      "description": "Collection of brands"
    },
    "orders": {
      "schema": "Order",
      "description": "Collection of orders"
    },
    "reviews": {
      "schema": "Review",
      "description": "Collection of reviews"
    }
  }
}

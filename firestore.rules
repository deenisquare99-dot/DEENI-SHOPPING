rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // HELPER FUNCTIONS
    // ---------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == 'deenisquare99@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ---------------------------------------------------------
    // VALIDATION HELPERS
    // ---------------------------------------------------------

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'images']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() > 0 &&
             data.images is list && data.images.size() > 0 &&
             (data.get('discountPrice', 0) is number) &&
             (data.get('isFeatured', false) is bool) &&
             (data.get('isNewArrival', false) is bool) &&
             (data.get('isBestSeller', false) is bool);
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'slug']) &&
             data.name is string && data.name.size() > 0 &&
             data.slug is string && data.slug.size() > 0;
    }

    function isValidBrand(data) {
      return data.keys().hasAll(['name', 'slug']) &&
             data.name is string && data.name.size() > 0 &&
             data.slug is string && data.slug.size() > 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['items', 'total', 'status', 'paymentMethod', 'customerName', 'phone', 'address', 'city', 'createdAt']) &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['Pending', 'Processing', 'Shipped', 'Delivered', 'Cancelled'] &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.phone is string && data.phone.size() > 0 &&
             data.createdAt == request.time;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['userName', 'rating', 'comment', 'createdAt']) &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() <= 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() > 0 && data.comment.size() <= 1000 &&
             data.createdAt == request.time;
    }

    // ---------------------------------------------------------
    // DEFAULT DENY
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // COLLECTIONS
    // ---------------------------------------------------------

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCategory(incoming());
      allow update: if isAdmin() && isValidCategory(incoming());
      allow delete: if isAdmin();
    }

    match /brands/{brandId} {
      allow read: if true;
      allow create: if isAdmin() && isValidBrand(incoming());
      allow update: if isAdmin() && isValidBrand(incoming());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isValidOrder(incoming());
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidReview(incoming());
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Managed via console/backend
    }
  }
}
